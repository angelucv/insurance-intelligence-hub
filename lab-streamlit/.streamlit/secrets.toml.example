# Copiar a secrets.toml (local) o pegar en Streamlit Community Cloud → App settings → Secrets.
# URL pública de la API tras desplegar en Render (sin barra final).

COMPUTE_API_URL = "https://insurance-hub-api-xxxx.onrender.com"

# Opcional: misma clave que INGEST_API_KEY en la API (si la definiste allí).
# INGEST_API_KEY = "tu-clave-secreta"
