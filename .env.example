# Copiar a .env y rellenar (no commitear .env)

# --- App ---
APP_ENV=development
APP_NAME=insurance-intelligence-hub

# --- PostgreSQL / Supabase (API + Django) ---
# DATABASE_URL=postgresql://user:pass@host:5432/postgres

# --- API compute (FastAPI) ---
API_HOST=0.0.0.0
API_PORT=8000

# Si defines INGEST_API_KEY, POST /api/v1/ingest/policies exige cabecera X-API-Key.
# INGEST_API_KEY=una-clave-larga-aleatoria

# --- Observabilidad (opcional) ---
# SENTRY_DSN=

# --- Auth / JWT (fases futuras) ---
# JWT_SECRET=

# --- URLs entre servicios ---
# COMPUTE_API_URL=http://127.0.0.1:8000

# --- Django (backend-ingest) ---
# DJANGO_SECRET_KEY=cambia-esto
# DEBUG=true
# ALLOWED_HOSTS=localhost,127.0.0.1

# --- CORS (API) — lista separada por coma o * para demo ---
# CORS_ALLOW_ORIGINS=*
