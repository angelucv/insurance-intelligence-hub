# Copiar a .env y rellenar (no commitear .env)

# --- App ---
APP_ENV=development
APP_NAME=insurance-intelligence-hub

# --- Base de datos (ej. PostgreSQL / Supabase) ---
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- API compute ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Observabilidad (opcional) ---
# SENTRY_DSN=

# --- Auth / JWT (cuando apliques) ---
# JWT_SECRET=

# --- URLs entre servicios (desarrollo) ---
# COMPUTE_API_URL=http://127.0.0.1:8000
